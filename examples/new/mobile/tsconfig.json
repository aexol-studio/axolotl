{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ]
    }
  },
  "include": [
    "app",
    "src",
    "templates",
    "expo-env.d.ts",
    "src/types/**/*.d.ts",
    ".expo/types/**/*.ts"
  ],
  "exclude": [
    "**/*.stories.tsx"
  ]
}
