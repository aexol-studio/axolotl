{
  "name": "axolotl-mobile",
  "private": true,
  "version": "0.1.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "start:mcp": "EXPO_UNSTABLE_MCP_SERVER=1 expo start",
    "start:storybook": "EXPO_PUBLIC_STORYBOOK_ENABLED=1 expo start -c",
    "storybook:generate": "sb-rn-get-stories -c ./.storybook",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "lint": "eslint --no-config-lookup --config ./eslint.config.mjs \"src/**/*.{ts,tsx}\" \"app/**/*.{ts,tsx}\"",
    "lint:fix": "eslint --no-config-lookup --config ./eslint.config.mjs \"src/**/*.{ts,tsx}\" \"app/**/*.{ts,tsx}\" --fix",
    "typecheck": "tsc --noEmit",
    "test": "jest"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@shopify/flash-list": "2.0.2",
    "@tanstack/react-query": "^5.90.5",
    "expo": "^54.0.0",
    "expo-blur": "~15.0.7",
    "expo-constants": "~18.0.10",
    "expo-linking": "~8.0.8",
    "expo-localization": "~17.0.7",
    "expo-router": "~6.0.0",
    "graphql": "^16.12.0",
    "graphql-zeus": "^7.2.1",
    "i18next": "^25.6.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-i18next": "^16.0.1",
    "react-native": "0.81.5",
    "react-native-reanimated": "~4.1.1",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-keyboard-controller": "1.18.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-worklets": "0.5.1",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@storybook/addon-ondevice-actions": "^8.6.4",
    "@storybook/react": "^8.6.4",
    "@storybook/react-native": "^8.6.4",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/react": "~19.1.10",
    "babel-preset-expo": "^54.0.10",
    "eslint": "^9.37.0",
    "jest": "~29.7.0",
    "jest-expo": "^54.0.13",
    "react-test-renderer": "19.1.0",
    "typescript": "~5.9.2"
