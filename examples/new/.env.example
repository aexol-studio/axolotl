# === Secrets (required for production) ===
# These MUST be set. Never commit real values.

DATABASE_URL="postgresql://axolotl:axolotl@localhost:5533/axolotl?schema=public"

# JWT secret for signing auth tokens — change this in production!
JWT_SECRET="your-secret-key-change-in-production"

# OpenAI API Key for AI SDK integration
# Get your key from https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-..."

# Dev Translate API Key for auto-generating translations
# Used by @aexol/vite-plugin-dev-translate at build time
DEV_TRANSLATE_API_KEY=your-api-key-here

# Email mode (local | mailgun). Defaults to local.
EMAIL_MODE="local"

# Set true to skip verification gate. Defaults to true.
DISABLE_EMAIL_VERIFICATION="true"

# Mailgun API key (required when EMAIL_MODE='mailgun')
MAILGUN_API_KEY="your-mailgun-api-key"

# Mailgun sending config (required when EMAIL_MODE='mailgun')
MAILGUN_DOMAIN="your-mailgun-domain"
MAILGUN_SENDER="Axolotl <no-reply@your-mailgun-domain>"

# Optional Mailgun API URL override (EU default is used when omitted)
MAILGUN_URL="https://api.eu.mailgun.net"

# === Production Overrides (optional — derived from defaults locally) ===
# These have sensible defaults for local dev. Only set in production.

# Application URL for email links. Defaults to http://localhost:{PORT}.
# Only needed in production where you have a real domain.
APP_URL="https://yourdomain.com"

# Server port. Defaults to 8080.
PORT=8080

# === E2E Testing (optional — only for running Playwright tests) ===

# Base URL for E2E tests (the running frontend)
E2E_URL="http://localhost:8080"

# Note: No TESTING_USER_* variables are required for E2E setup.
